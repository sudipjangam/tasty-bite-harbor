graph TB
    subgraph Client["Frontend (React + Vite)"]
        direction TB
        App["App.tsx"]
        
        subgraph Providers["Provider Stack"]
            QC["QueryClientProvider"]
            TP["ThemeProvider"]
            AP["AuthProvider"]
            AcP["AccessProvider (RBAC)"]
            CP["CurrencyProvider"]
            NP["NetworkStatusProvider"]
        end

        subgraph PublicPages["Public Routes"]
            Landing["LandingWebsite /"]
            Auth["Auth /auth"]
            QROrder["CustomerOrder /order/:data"]
            PubBill["PublicBillPage /bill/:data"]
            Truck["PublicTruckPage /truck/:slug"]
            Enroll["PublicEnrollmentPage /enroll/:slug"]
        end

        subgraph AppRoutes["Authenticated Routes (AppRoutes)"]
            direction LR
            subgraph Operations["Operations"]
                POS["POS"]
                QSRPOS["QSR POS"]
                QuickServe["QuickServe POS"]
                Kitchen["Kitchen Display"]
                Orders["Orders"]
            end
            subgraph Management["Management"]
                MenuPage["Menu"]
                Recipes["Recipes"]
                Inventory["Inventory"]
                Suppliers["Suppliers"]
                Tables["Tables"]
            end
            subgraph Hotel["Hotel/PMS"]
                Rooms["Rooms"]
                Housekeeping["Housekeeping"]
                Reservations["Reservations"]
                ChannelMgmt["Channel Mgmt"]
                Revenue["Revenue Mgmt"]
            end
            subgraph Finance["Finance & Analytics"]
                Dashboard["Dashboard"]
                Analytics["Analytics"]
                Financial["Financial"]
                Expenses["Expenses"]
                Reports["Reports"]
            end
            subgraph People["People"]
                Staff["Staff"]
                Customers["Customers / CRM"]
                Marketing["Marketing"]
                UserMgmt["User Management"]
                RoleMgmt["Role Management"]
            end
            subgraph AIFeatures["AI"]
                AIChat["AI Assistant"]
            end
            subgraph PlatformAdmin["Platform Admin"]
                PlatformDash["Platform Dashboard"]
                RestMgmt["Restaurant Management"]
                SubsMgmt["Subscription Manager"]
            end
        end
    end

    subgraph Backend["Supabase Backend"]
        direction TB
        SupaAuth["Auth Service"]
        SupaDB["PostgreSQL Database"]
        SupaStorage["Storage (Images)"]
        subgraph EdgeFunctions["Edge Functions (Deno)"]
            EF1["chat-with-gemini"]
            EF2["submit-qr-order"]
            EF3["deduct-inventory-on-prep"]
            EF4["send-whatsapp / email"]
            EF5["payment (Paytm QR)"]
            EF6["user/role-management"]
            EF7["sync-channels"]
            EF8["Other 30+ functions"]
        end
    end

    subgraph External["External Services"]
        Gemini["Google Gemini AI"]
        MSG91["MSG91 (WhatsApp)"]
        Paytm["Paytm (Payments)"]
        Netlify["Netlify (Hosting)"]
    end

    App --> Providers
    Providers --> PublicPages
    Providers --> AppRoutes

    AppRoutes --> SupaDB
    AppRoutes --> SupaAuth
    PublicPages --> SupaDB

    EdgeFunctions --> SupaDB
    EdgeFunctions --> SupaStorage
    EF1 --> Gemini
    EF4 --> MSG91
    EF5 --> Paytm
    Client --> Netlify
